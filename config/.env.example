# ─── Environment Variables ───
# Copy this to .env and fill in your values

# Solana RPC (free-tier)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# For premium RPC (Helius, QuickNode, etc.)
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# Wallet (ONLY for LIVE mode — keep this SECRET)
# Base58-encoded private key or path to keypair JSON file
WALLET_PRIVATE_KEY=
WALLET_KEYPAIR_PATH=

# Bot mode override (overrides config.toml)
# BOT_MODE=BACKTEST

# Logging
LOG_LEVEL=INFO

# ML model paths (optional overrides)
# NN_MODEL_PATH=ml/saved_models/nn_model.pt
# XGB_MODEL_PATH=ml/saved_models/xgb_model.json
