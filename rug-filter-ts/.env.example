# ─── Rug Filter ML System Configuration ───

# ── API Keys ──
GOPLUS_API_KEY=your_goplus_api_key_here
HONEYPOT_API_KEY=your_honeypot_api_key_here
HELIUS_API_KEY=your_helius_api_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
UNICRYPT_API_KEY=your_unicrypt_api_key_here

# ── Model Paths ──
# Autoencoder for anomaly detection
ANOMALY_MODEL_PATH=./models/autoencoder.pt

# Specialist model paths
CONTRACT_MODEL_PATH=./models/contract_model.pkl
WALLET_MODEL_PATH=./models/wallet_model.pkl
LIQUIDITY_MODEL_PATH=./models/liquidity_model.pkl
SOCIAL_MODEL_PATH=./models/social_model.pkl

# ── Python Runtime ──
# Path to Python executable or "python" if in PATH
PYTHON_PATH=python

# Optional: HTTP model server URL
# If set, models will be queried via HTTP instead of subprocess
# Example: http://localhost:5000
PYTHON_SERVER_URL=

# ── Database ──
# SQLite database path for feedback logging
FEEDBACK_DB_PATH=./feedback.db

# ── Redis (Optional) ──
# For caching signal extraction results
REDIS_URL=

# ── ML Tuning ──
# Minimum feedback records required before retraining
MIN_FEEDBACK=100

# EWC Fisher information penalty factor (λ)
# Higher = more conservative, slower learning
# Lower = faster learning, more catastrophic forgetting risk
EWC_PENALTY=0.4

# ── Logging ──
# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO

# Optional: log file path  
LOG_FILE_PATH=

# v3 sniper runtime
HEALTH_PORT=8080
TARGET_P95_LATENCY_MS=50
HELIUS_STREAM_COUNT=20
JITO_AUTH_KEY=
JITO_BUNDLE_FANOUT=200
JITO_WALLET_SECRETS=wallet_a,wallet_b,wallet_c,wallet_d
WALLET_ROTATION_TRADES=100
STRESS_RUG_THRESHOLD=0.15
DEPLOYER_BLACKLIST=
CAPITAL_BASE_SOL=8000
BURST_CAPITAL_SOL=8000
TARGET_BURST_PNL_SOL=392
CAPITAL_ALLOCATION_PCT=0.05
