{
  "name": "meme-coin-bot",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript Solana meme-coin sniper engine with paper-first execution, risk gating, RugCheck integration, Jito bundle routing, wallet rotation, and deterministic stress tests.",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "paper": "node --experimental-strip-types src/index.ts paper",
    "live": "cross-env LIVE_TRADING=true node --experimental-strip-types src/index.ts live",
    "stress": "npm run backtest",
    "test": "node --experimental-strip-types tests/run_ts_tests.ts",
    "backtest": "node --experimental-strip-types backtest/scenarios.ts",
    "backtest:scenarios": "node --experimental-strip-types backtest/scenarios.ts",
    "train:ml": "node --experimental-strip-types scripts/run_train_ml.ts",
    "validate:features": "python ml/validate_features.py",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "meme-coin",
    "jito",
    "rugcheck",
    "sniper",
    "paper-trading"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "onnxruntime-node": "1.25.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "ioredis": "^5.4.2",
    "jito-js-rpc": "^0.2.2",
    "pino": "^9.6.0",
    "undici": "^7.2.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.2"
  }
}
